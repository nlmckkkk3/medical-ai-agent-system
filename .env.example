# ====================================================
# MedChoice 环境配置文件（模板）
# ====================================================
# 注意：将本文件复制为 .env 后填写真实 API Key。
# ⚠️ .env 文件包含敏感信息，请勿提交到代码仓库！
# 建议使用此模板进行配置，确保安全。
# ====================================================

# LLM API Configuration
# Choose provider: deepseek or zhipu
LLM_PROVIDER=deepseek

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Zhipu API (GLM)
ZHIPU_API_KEY=your-zhipu-key-here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4.6v

# RAG Mode: keyword (lightweight, no downloads) or embedding (semantic BGE via ModelScope)
RAG_MODE=keyword

# Embedding Model (used when RAG_MODE=embedding, downloaded from ModelScope)
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# Vector Database
CHROMA_DB_PATH=./data/chroma_db

# User Data Storage
USER_DATA_PATH=./data/user_profiles

# OCR: Tesseract executable path (optional, auto-detected if not set)
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
